{
  "name": "zapdesk",
  "version": "1.0.6",
  "description": "Cliente desktop alternativo e estavel para WhatsApp Web.",
  "author": "ZapDesk",
  "private": true,
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:main": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electronmon .",
    "build": "npm run clean && npm run typecheck && vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder --win nsis",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist release"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "electron-store": "^10.1.0",
    "lucide-react": "^0.561.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electronmon": "^2.0.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.zapdesk.app",
    "productName": "ZapDesk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "ZapDesk-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "uninstallDisplayName": "ZapDesk",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
